<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I Love You Barkha Babe ❤️</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background:linear-gradient(90deg,#5d2b90,#9c4dff,#5b2f91,#74d6d3);
            overflow:hidden;
        }

        .container{
            text-align:center;
            color:white;
        }

        h1{
            font-size:60px;
            font-weight:bold;
            text-shadow:0 5px 15px rgba(0,0,0,0.3);
            animation:fadeIn 2s ease-in-out;
        }

        p{
            margin-top:20px;
            font-size:24px;
            letter-spacing:2px;
            animation:fadeIn 3s ease-in-out;
        }

        .heart{
            color:red;
            animation:beat 1s infinite;
        }

        @keyframes beat{
            0%{transform:scale(1);}
            50%{transform:scale(1.3);}
            100%{transform:scale(1);}
        }

        @keyframes fadeIn{
            from{
                opacity:0;
                transform:translateY(30px);
            }
            to{
                opacity:1;
                transform:translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>
            I Love You
            <span class="heart">❤️</span>
            Barkha Babe
        </h1>

        <p>Forever & Always 💕</p>
    </div>

</body>
</html>
